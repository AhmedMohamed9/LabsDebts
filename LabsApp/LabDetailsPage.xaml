<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:LabsApp.Converters"
    x:Class="LabsApp.LabDetailsPage"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#121212"
    FlowDirection="RightToLeft">

    <!-- Resources -->

    <ContentPage.Resources>

        <ResourceDictionary>

            <converters:PaidColorConverter
                x:Key="PaidColorConverter"/>

        </ResourceDictionary>

    </ContentPage.Resources>

    <!-- ROOT -->

    <Grid>

        <!-- MAIN CONTENT -->

        <CollectionView
            x:Name="TransactionsList"
            RemainingItemsThreshold="2"
            RemainingItemsThresholdReached="OnLoadMore"
            BackgroundColor="Transparent">

            <!-- HEADER -->

            <CollectionView.Header>

                <VerticalStackLayout
                    Padding="20"
                    Spacing="20">

                    <!-- Back Button -->

                    <Button
                        Text="رجوع"
                        Clicked="OnBackClicked"
                        BackgroundColor="#333333"
                        TextColor="White"
                        HorizontalOptions="Start"/>

                    <!-- Title -->

                    <Label
                        Text="تفاصيل المعمل"
                        FontSize="30"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalOptions="Center"/>

                    <!-- Lab Info -->

                    <Frame
                        BackgroundColor="#1E1E1E"
                        BorderColor="#333333"
                        CornerRadius="18"
                        Padding="18">

                        <Grid ColumnDefinitions="*,Auto">

                            <!-- Left -->

                            <VerticalStackLayout
                                Grid.Column="0"
                                Spacing="6">

                                <Label
                                    Text="اسم المعمل"
                                    TextColor="Gray"
                                    FontSize="14"/>

                                <Label
                                    x:Name="NameLabel"
                                    FontSize="26"
                                    FontAttributes="Bold"
                                    TextColor="White"/>

                            </VerticalStackLayout>

                            <!-- Right -->

                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="4"
                                HorizontalOptions="End"
                                VerticalOptions="Center">

                                <Label
                                    Text="الكود"
                                    TextColor="Gray"
                                    FontSize="13"/>

                                <Label
                                    x:Name="CodeLabel"
                                    TextColor="#6C63FF"
                                    FontSize="22"
                                    FontAttributes="Bold"/>

                            </VerticalStackLayout>

                        </Grid>

                    </Frame>

                    <!-- Total -->

                    <Frame
                        BackgroundColor="#2A2A2A"
                        BorderColor="#444444"
                        CornerRadius="18"
                        Padding="18">

                        <Grid ColumnDefinitions="Auto,*">

                            <!-- Icon -->

                            <Label
                                Grid.Column="0"
                                Text="💰"
                                FontSize="32"/>

                            <!-- Content -->

                            <VerticalStackLayout
                                Grid.Column="1"
                                Margin="15,0,0,0">

                                <Label
                                    Text="إجمالي المديونيات غير المدفوعة"
                                    TextColor="Gray"
                                    FontSize="14"/>

                                <Label
                                    x:Name="TotalUnpaidLabel"
                                    Text="0"
                                    FontSize="28"
                                    FontAttributes="Bold"
                                    TextColor="#FFB74D"/>

                            </VerticalStackLayout>

                        </Grid>

                    </Frame>

                    <!-- Add Button -->

                    <Button
                        Text="إضافة مديونية"
                        Clicked="OnShowTransactionPopup"
                        BackgroundColor="#6C63FF"
                        TextColor="White"
                        CornerRadius="12"/>

                </VerticalStackLayout>

            </CollectionView.Header>

            <!-- ITEMS -->

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Frame
                        Margin="20,5"
                        Padding="12"
                        BackgroundColor="#1E1E1E"
                        BorderColor="#333333"
                        CornerRadius="12">

                        <!-- Double Tap -->

                        <Frame.GestureRecognizers>

                            <TapGestureRecognizer
                                NumberOfTapsRequired="2"
                                Tapped="OnTransactionDoubleTapped"
                                CommandParameter="{Binding .}" />

                        </Frame.GestureRecognizers>

                        <VerticalStackLayout Spacing="10">

                            <!-- Top Row -->

                            <Grid ColumnDefinitions="*,Auto,Auto">

                                <!-- Amount -->

                                <Label
                                    Grid.Column="0"
                                    Text="{Binding Amount}"
                                    TextColor="White"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    VerticalOptions="Center"/>

                                <!-- Paid -->

                                <Button
                                    Grid.Column="1"
                                    Text="●"
                                    Clicked="OnPaidClicked"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="Transparent"
                                    TextColor="{Binding IsPaid, Converter={StaticResource PaidColorConverter}}"
                                    FontSize="30"/>

                                <!-- Delete -->

                                <Button
                                    Grid.Column="2"
                                    Text="🗑"
                                    Clicked="OnDeleteTransactionClicked"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="Transparent"
                                    TextColor="Red"
                                    FontSize="22"/>

                            </Grid>

                            <!-- Note -->

                            <Label
                                Text="{Binding Note}"
                                TextColor="#BBBBBB"
                                FontSize="14"/>

                            <!-- Dates -->

                            <Grid ColumnDefinitions="*,*">

                                <Label
                                    Grid.Column="0"
                                    Text="{Binding Date, StringFormat='التاريخ: {0:dd/MM/yyyy}'}"
                                    TextColor="#CCCCCC"
                                    FontSize="12"/>

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding DueDate, StringFormat='تاريخ الدفع: {0:dd/MM/yyyy}'}"
                                    TextColor="#CCCCCC"
                                    FontSize="12"
                                    HorizontalOptions="End"/>

                            </Grid>

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- POPUP OVERLAY -->

        <Grid
            x:Name="PopupOverlay"
            IsVisible="False"
            BackgroundColor="#66000000"
            ZIndex="99">

            <!-- Bottom Sheet -->

            <Frame
                x:Name="PopupFrame"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                Margin="0"
                Padding="25"
                BackgroundColor="#1E1E1E"
                BorderColor="#333333"
                CornerRadius="30">

                <VerticalStackLayout Spacing="18">

                    <!-- Handle -->

                    <BoxView
                        HeightRequest="5"
                        WidthRequest="60"
                        CornerRadius="3"
                        Color="#666666"
                        HorizontalOptions="Center"/>

                    <!-- Title -->

                    <Label
                        Text="إضافة / تعديل مديونية"
                        FontSize="26"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalOptions="Center"/>

                    <!-- Amount -->

                    <Entry
                        x:Name="AmountEntry"
                        Placeholder="المبلغ"
                        Keyboard="Numeric"
                        TextColor="White"
                        PlaceholderColor="Gray"
                        BackgroundColor="#2A2A2A"/>

                    <!-- Note -->

                    <Editor
                        x:Name="NoteEditor"
                        Placeholder="ملاحظات"
                        TextColor="White"
                        PlaceholderColor="Gray"
                        HeightRequest="100"
                        BackgroundColor="#2A2A2A"/>

                    <!-- Date -->

                    <Label
                        Text="التاريخ"
                        TextColor="White"
                        FontAttributes="Bold"/>

                    <DatePicker
                        x:Name="TransactionDatePicker"
                        TextColor="White"/>



                    <!-- Paid -->

                    <HorizontalStackLayout Spacing="10">

                        <CheckBox
                            x:Name="IsPaidCheckBox"
                            CheckedChanged="OnPaidCheckedChanged"
                            Color="#6C63FF"/>

                        <Label
                            Text="تم الدفع"
                            TextColor="White"
                            VerticalOptions="Center"/>

                    </HorizontalStackLayout>
                    <Label
    x:Name="PaidDateLabel"
    Text="تاريخ الدفع"
    TextColor="White"
    FontAttributes="Bold"
    IsVisible="False"/>

                    <!-- Due Date -->

                    <DatePicker
                        x:Name="DueDatePicker"
                        IsVisible="False"
                        TextColor="White"/>
                    <!-- Buttons -->

                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="10">

                        <Button
                            Text="حفظ"
                            Clicked="OnAddTransactionClicked"
                            BackgroundColor="#6C63FF"
                            TextColor="White"
                            CornerRadius="14"/>

                        <Button
                            Grid.Column="1"
                            Text="إلغاء"
                            Clicked="OnClosePopup"
                            BackgroundColor="#333333"
                            TextColor="White"
                            CornerRadius="14"/>

                    </Grid>

                </VerticalStackLayout>

            </Frame>

        </Grid>

    </Grid>

</ContentPage>